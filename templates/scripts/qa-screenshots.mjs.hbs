// QA full-site screenshot capture — {{brand.name}}
// Runs against production deploy by default (BASE env to override).
// Generated by Designer OS from brand book.

import { chromium } from "playwright";
import { mkdir, writeFile } from "node:fs/promises";
import path from "node:path";

const BASE    = process.env.BASE || "{{deploy.domain ? 'https://' + deploy.domain : 'http://localhost:3000'}}";
const OUTDIR  = path.join(process.cwd(), "screenshots");
const VIEWPORT = { width: 1440, height: 900 };
const MOBILE   = { width: 390,  height: 844 };
const SETTLE_MS = 1200;
const FULL_PAGE = false;

// ─── Routes ─────────────────────────────────────────────────────────────────
// Generated from brand book surfaces + key_routes.
// Add new routes here as you build features.
// Format: ["section-prefix", [ { name: "slug", path: "/url" }, ... ]]

const ROUTES = [
  // Design system viewers (always present)
  ["00-design-system", [
    { name: "01-tokens-primitive", path: "/tokens/primitive" },
    { name: "02-tokens-semantic",  path: "/tokens/semantic" },
    { name: "03-tokens-mobile",    path: "/tokens/mobile" },
    { name: "04-components",       path: "/components" },
  ]],

  // System pages
  ["05-system", [
    { name: "01-404", path: "/this-route-does-not-exist" },
  ]],

{{#if (includes product.surfaces "marketing")}}
  // Marketing surface
  ["10-marketing", [
    { name: "01-home",    path: "/" },
{{#each product.key_routes}}{{#if (eq this.shell "site")}}    { name: "{{slugify this.name}}", path: "{{this.path}}" },
{{/if}}{{/each}}  ]],
{{/if}}

{{#if (includes product.surfaces "auth")}}
  // Auth surface
  ["20-auth", [
    { name: "01-login",  path: "/login" },
    { name: "02-signup", path: "/signup" },
  ]],
{{/if}}

{{#if (includes product.surfaces "onboarding")}}
  // Onboarding surface
  ["30-onboarding", [
    { name: "01-onboarding", path: "/onboarding" },
  ]],
{{/if}}

{{#if (includes product.surfaces "product-app")}}
  // Product app surface
  ["40-app", [
    { name: "01-dashboard", path: "/dashboard" },
{{#each product.key_routes}}{{#if (eq this.shell "app")}}    { name: "{{slugify this.name}}", path: "{{this.path}}" },
{{/if}}{{/each}}  ]],
{{/if}}

{{#if (includes product.surfaces "admin")}}
  // Admin surface
  ["90-admin", [
    { name: "01-admin", path: "/admin" },
{{#each product.key_routes}}{{#if (eq this.name "Admin")}}    { name: "01-admin-home", path: "{{this.path}}" },
{{/if}}{{/each}}  ]],
{{/if}}
];

const flatRoutes = ROUTES.flatMap(([dir, items]) => items.map((r) => ({ dir, ...r })));
const TOTAL = flatRoutes.length;

async function shoot(page, route, viewport) {
  const target = `${BASE}${route.path}`;
  const outDir = path.join(OUTDIR, route.dir);
  await mkdir(outDir, { recursive: true });
  const outPath = path.join(outDir, `${route.name}.png`);

  try {
    await page.setViewportSize(viewport);
    await page.goto(target, { waitUntil: "networkidle", timeout: 30_000 });
    await page.waitForTimeout(SETTLE_MS);
    await page.screenshot({ path: outPath, fullPage: FULL_PAGE });
    return { ok: true, route: route.path, file: outPath };
  } catch (err) {
    return { ok: false, route: route.path, error: err.message };
  }
}

(async () => {
  console.log(`\n📸 {{brand.name}} QA capture — ${TOTAL} routes`);
  console.log(`   Target: ${BASE}`);
  console.log(`   Output: ${OUTDIR}\n`);

  await mkdir(OUTDIR, { recursive: true });

  const browser = await chromium.launch();
  const context = await browser.newContext({
    viewport: VIEWPORT,
    deviceScaleFactor: 2,
    colorScheme: "light",
  });
  const page = await context.newPage();

  // Set theme to light explicitly
  await page.goto(BASE);
  await page.evaluate(() => {
    try {
      document.documentElement.classList.remove("dark");
      localStorage.setItem("theme", "light");
    } catch {}
  });

  const results = [];
  let i = 0;
  for (const route of flatRoutes) {
    i++;
    process.stdout.write(`  [${String(i).padStart(2, "0")}/${TOTAL}] ${route.path.padEnd(55)} `);
    const result = await shoot(page, route, VIEWPORT);
    console.log(result.ok ? "✓" : `✗ ${result.error}`);
    results.push(result);
  }

  // Mobile snapshots for key surfaces
  const MOBILE_KEY = [
{{#if (includes product.surfaces "marketing")}}
    { dir: "10-marketing", name: "01-home-mobile",      path: "/" },
{{/if}}
{{#if (includes product.surfaces "auth")}}
    { dir: "20-auth",      name: "01-login-mobile",     path: "/login" },
{{/if}}
{{#if (includes product.surfaces "product-app")}}
    { dir: "40-app",       name: "01-dashboard-mobile", path: "/dashboard" },
{{/if}}
    { dir: "00-design-system", name: "03-tokens-mobile-mobile", path: "/tokens/mobile" },
  ];

  console.log(`\n📱 Mobile snapshots — ${MOBILE_KEY.length} routes\n`);
  for (const r of MOBILE_KEY) {
    process.stdout.write(`  ${r.path.padEnd(55)} `);
    const result = await shoot(page, r, MOBILE);
    console.log(result.ok ? "✓" : `✗ ${result.error}`);
    results.push(result);
  }

  await browser.close();

  const ok   = results.filter((r) => r.ok).length;
  const fail = results.length - ok;
  console.log(`\n✅ ${ok} / ${results.length} captured · ${fail} failed`);
  if (fail > 0) {
    console.log(`\nFailed:`);
    results.filter((r) => !r.ok).forEach((r) => console.log(`  ${r.route} — ${r.error}`));
  }

  // Write index
  const index = ROUTES.map(([dir, items]) => ({
    section: dir,
    items: items.map((it) => ({ name: it.name, path: it.path })),
  }));
  await writeFile(path.join(OUTDIR, "_index.json"), JSON.stringify(index, null, 2));
  console.log(`\n📄 Index written: ${path.join(OUTDIR, "_index.json")}`);
})();
